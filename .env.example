# ---- Copy this file to .env and fill in the values (or paste into Vercel → Environment Variables) ----

# Firebase (public web config — safe to expose; already has fallbacks in code)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI (SECRET — server-side only, never commit the real value)
GEMINI_API_KEY=your_gemini_api_key
# Optional — model override (defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
